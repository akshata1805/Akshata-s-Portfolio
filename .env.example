# ─────────────────────────────────────────────
#  EmailJS Configuration
#  Copy this file to .env and fill in your keys
# ─────────────────────────────────────────────

# 1. Go to https://www.emailjs.com → Account → General
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here

# 2. Email Services tab → Add Service → Copy Service ID
VITE_EMAILJS_SERVICE_ID=your_service_id_here

# 3. Email Templates tab → Create Template → Copy Template ID
#    Template must have variables: {{from_name}} {{from_email}} {{subject}} {{message}}
VITE_EMAILJS_TEMPLATE_ID=your_template_id_here
